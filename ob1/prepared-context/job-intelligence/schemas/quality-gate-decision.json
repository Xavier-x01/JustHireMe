{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "ob1://job-intelligence/quality-gate-decision",
  "title": "QualityGateDecision",
  "description": "Deterministic verdict on a raw lead before it enters ranking.",
  "type": "object",
  "required": ["job_id", "pass", "reason", "penalty_score", "checks"],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{32}$"
    },
    "pass": {
      "type": "boolean",
      "description": "True if lead cleared all hard-reject checks."
    },
    "reason": {
      "type": "string",
      "description": "Primary reason for pass or fail."
    },
    "penalty_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Total penalty deducted from base score before ranking."
    },
    "checks": {
      "type": "object",
      "description": "Individual check results.",
      "properties": {
        "url_exists":      { "type": "boolean" },
        "posting_depth":   { "type": "string", "enum": ["pass", "penalty", "fail"] },
        "freshness":       { "type": "string", "enum": ["pass", "penalty", "fail"] },
        "seniority_check": { "type": "string", "enum": ["pass", "penalty", "fail"] },
        "red_flags":       { "type": "string", "enum": ["pass", "penalty", "fail"] },
        "context":         { "type": "string", "enum": ["pass", "penalty", "fail"] }
      }
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
